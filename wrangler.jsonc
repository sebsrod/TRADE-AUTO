{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "trade-auto",
  "compatibility_date": "2025-06-01",

  // Cloudflare Pages project. The SPA is built to dist/client and the API runs as a
  // Pages Function (functions/api/[[route]].ts). Bindings below are applied on deploy.
  "pages_build_output_dir": "dist/client",

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "trade-auto-db",
      "database_id": "6308332d-d87d-4b14-8a8b-ff0e4a68c6cf",
      "migrations_dir": "migrations"
    }
  ],

  // Non-secret config. GEMINI_API_KEY is a secret: `wrangler pages secret put GEMINI_API_KEY`.
  // NOTE: Pages cannot run cron triggers — scheduling is handled by the companion
  // cron Worker in ./cron (see README). Manual runs work via POST /api/ai/run-cycle.
  "vars": {
    "GEMINI_MODEL": "gemini-2.5-flash",
    "GEMINI_DISCOVERY_MODEL": "gemini-2.5-flash",
    "DEFAULT_USER_ID": "1",
    "ENABLE_SEARCH_GROUNDING": "false",
    "CRON_AUTO_TRADE": "true"
  }
}
