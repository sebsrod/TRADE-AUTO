{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "trade-auto",
  "main": "src/worker/index.ts",
  "compatibility_date": "2025-06-01",

  // The Worker runs first for every request. It handles /api/* itself and
  // delegates everything else to the static-asset bundle (the built SPA).
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },

  // Cloudflare D1 (edge SQLite). Replace database_id after `npm run db:create`.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "trade-auto-db",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations"
    }
  ],

  // AI market-scan + position-management cron. Runs every 2 hours (UTC).
  "triggers": {
    "crons": ["0 */2 * * *"]
  },

  "observability": { "enabled": true },

  // Non-secret config. Secrets (GEMINI_API_KEY etc.) are set with `wrangler secret put`.
  "vars": {
    "GEMINI_MODEL": "gemini-2.5-flash",
    "GEMINI_DISCOVERY_MODEL": "gemini-2.5-flash",
    "DEFAULT_USER_ID": "1",
    "ENABLE_SEARCH_GROUNDING": "false",
    "CRON_AUTO_TRADE": "true"
  }
}
