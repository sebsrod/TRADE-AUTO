{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "trade-auto-cron",
  "main": "index.ts",
  "compatibility_date": "2025-06-01",
  // Required by the Anthropic SDK (@anthropic-ai/sdk) on the Workers runtime.
  "compatibility_flags": ["nodejs_compat"],

  // Companion scheduling Worker for the Pages app. Pages can't run cron triggers,
  // so this tiny Worker runs the analysis cycle on a schedule against the SAME D1.
  // It has no public routes; it shares the database + service code with the app.
  // Runs every 30 minutes so auto-trade acts promptly. NOTE: this Worker needs its
  // OWN ANTHROPIC_API_KEY secret (`wrangler secret put ANTHROPIC_API_KEY --config cron/wrangler.jsonc`);
  // without it, discovery throws and the scheduled cycle opens nothing.
  "triggers": {
    "crons": ["*/30 * * * *"]
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "trade-auto-db",
      "database_id": "6308332d-d87d-4b14-8a8b-ff0e4a68c6cf",
      "migrations_dir": "../migrations"
    }
  ],

  "observability": { "enabled": true },

  "vars": {
    "CLAUDE_MODEL": "claude-opus-4-8",
    "CLAUDE_DISCOVERY_MODEL": "claude-opus-4-8",
    "DEFAULT_USER_ID": "1",
    "CRON_AUTO_TRADE": "true"
  }
}
